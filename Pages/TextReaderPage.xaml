<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TXTReader.Controls"
             x:Class="TXTReader.Pages.TextReaderPage"
             x:Name="TextReaderPageRoot">

    <Grid RowDefinitions="Auto,*">

        <!-- Barra de busqueda -->
        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Margin="10,10,10,4">
            <Border StrokeThickness="0"
                    Padding="0"
                    Margin="12,8"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>
                <Entry x:Name="SearchEntry"
                       FontSize="14"
                       BackgroundColor="Transparent"
                       Margin="15,0"
                       TextChanged="OnSearchTextChanged" />
            </Border>
        </Border>

        <!-- Contenido con control de zoom -->
        <Grid Grid.Row="1" Margin="10,4,10,10" ColumnDefinitions="50,*">

            <!-- Zoom (slider vertical) -->
            <Border Grid.Column="0"
                    Style="{StaticResource Card}"
                    Margin="0,20,5,20">
                <Grid RowDefinitions="Auto,*,Auto" Padding="5">
                    <Label Grid.Row="0"
                           Text="A+"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           Margin="0,5" />

                    <Slider Grid.Row="1"
                            x:Name="ZoomSlider"
                            Minimum="8"
                            Maximum="32"
                            Value="14"
                            Rotation="270"
                            WidthRequest="150"
                            HeightRequest="40"
                            ThumbColor="{StaticResource Primary}"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource SeparatorLight}, Dark={StaticResource SeparatorDark}}"
                            ValueChanged="OnZoomSliderValueChanged"
                            VerticalOptions="Center"
                            HorizontalOptions="Center" />

                    <Label Grid.Row="2"
                           Text="A-"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           Margin="0,5" />
                </Grid>
            </Border>

            <!-- Texto -->
            <Border Grid.Column="1"
                    Style="{StaticResource Card}">
                <controls:SelectableHighlightedTextView
                    x:Name="ContentViewer"
                    Margin="14"
                    FontSize="14"
                    FontFamily="Monospace"
                    HighlightBackgroundColor="#FFE08A"
                    HighlightTextColor="#000000"
                    Foreground="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                    SearchTerm="{Binding Text, Source={x:Reference SearchEntry}}" />
            </Border>
        </Grid>

    </Grid>

</ContentPage>
