<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TXTReader.Pages.MainPage">

    <Grid RowDefinitions="Auto,*">

        <!-- Cabecera en color de marca -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Primary}"
                StrokeThickness="0"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>
            <VerticalStackLayout Padding="30,40,30,30" Spacing="10">
                <Label x:Name="MainTitleLabel"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       HorizontalOptions="Center" />
                <Label x:Name="MainSubtitleLabel"
                       FontSize="16"
                       TextColor="#D9CEF7"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <!-- Contenido -->
        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">

                <!-- Abrir fichero -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Padding="25" Spacing="15">
                        <Label x:Name="OpenFileLabel" Style="{StaticResource CardTitle}" />

                        <Button x:Name="SelectFileBtn"
                                Style="{StaticResource PrimaryButton}"
                                HeightRequest="55"
                                Clicked="OnSelectFileClicked"
                                HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Border>

                <!-- Recientes -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Padding="25,20" Spacing="15">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   x:Name="RecentFilesLabel"
                                   Style="{StaticResource CardTitle}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="🕒"
                                   FontSize="20"
                                   VerticalOptions="Center" />
                        </Grid>

                        <CollectionView x:Name="RecentFilesCollection"
                                        ItemsSource="{Binding RecentFiles}"
                                        HeightRequest="250">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
                                            StrokeThickness="0"
                                            Padding="0"
                                            Margin="0,5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnRecentFileSelected" />
                                            </Grid.GestureRecognizers>

                                            <Label Grid.Column="0"
                                                   Text="📄"
                                                   FontSize="18"
                                                   VerticalOptions="Center" />

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 Margin="12,0,0,0"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding FileName}"
                                                       Style="{StaticResource BodyText}"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding LastOpened, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                                       Style="{StaticResource HintText}" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   Style="{StaticResource HintText}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="20" HorizontalOptions="Center">
                                    <Label Text="📂"
                                           FontSize="40"
                                           HorizontalOptions="Center" />
                                    <Label Text="{Binding NoRecentFilesText}"
                                           Style="{StaticResource HintText}"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Acerca de -->
                <Button x:Name="AboutBtn"
                        Style="{StaticResource OutlineButton}"
                        Clicked="OnAboutClicked"
                        HorizontalOptions="Fill" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
