<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TXTReader.Pages.AboutPage"
             x:Name="AboutPageRoot">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Cabecera -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="30,25" Spacing="15">
                    <Label Text="📖" FontSize="60" HorizontalOptions="Center" />

                    <Label Text="TXT Reader"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalOptions="Center" />

                    <Label x:Name="VersionLabel"
                           Style="{StaticResource HintText}"
                           FontSize="16"
                           HorizontalOptions="Center" />

                    <Label x:Name="DescriptionLabel"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center" />

                    <Label Text="Socratic"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Contacto -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="ContactTitleLabel" Style="{StaticResource CardTitle}" />

                    <Button Text="jsoladelarosa@gmail.com"
                            Style="{StaticResource OutlineButton}"
                            Clicked="OnContactEmailClicked"
                            HorizontalOptions="Fill" />

                    <Label x:Name="ContactInstructionLabel"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Donacion -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="DonationTitleLabel"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Accent}" />

                    <Button x:Name="DonationButton"
                            Style="{StaticResource AccentButton}"
                            Clicked="OnKofiClicked"
                            HorizontalOptions="Fill" />

                    <Label x:Name="DonationDescriptionLabel"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Idioma -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="LanguageTitleLabel" Style="{StaticResource CardTitle}" />

                    <Picker x:Name="LanguagePicker"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                            BackgroundColor="Transparent"
                            SelectedIndexChanged="OnLanguagePickerChanged" />

                    <Label x:Name="LanguageDescriptionLabel"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Aviso legal -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="LegalTitleLabel"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Danger}" />

                    <Border StrokeThickness="0"
                            Padding="15"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="LegalText1Label"
                                   Style="{StaticResource BodyText}"
                                   FontSize="13"
                                   LineHeight="1.4" />

                            <Label x:Name="LegalText2Label"
                                   Style="{StaticResource BodyText}"
                                   FontSize="13"
                                   LineHeight="1.4" />

                            <Border StrokeThickness="0"
                                    Padding="12"
                                    BackgroundColor="{StaticResource Danger}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Label x:Name="WarningTextLabel"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       LineHeight="1.4"
                                       TextColor="{StaticResource White}"
                                       HorizontalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Volver -->
            <Button x:Name="BackButton"
                    Style="{StaticResource PrimaryButton}"
                    HeightRequest="50"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,20" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
