<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TXTReader.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:TXTReader.Pages"
    xmlns:mauiControls="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
    Shell.FlyoutBehavior="Flyout"
    Title="TXT Reader"
    FlyoutWidth="260"
    Shell.BackgroundColor="{StaticResource Primary}"
    Shell.ForegroundColor="{StaticResource White}"
    Shell.TitleColor="{StaticResource White}"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <!-- Plantilla de los items del menu: el texto toma color segun el tema con tokens
         (A.9); nunca un color fijo que quede invisible en modo oscuro. -->
    <Shell.ItemTemplate>
        <DataTemplate x:DataType="mauiControls:BaseShellItem">
            <Grid HeightRequest="52" Padding="20,0" ColumnDefinitions="24,*" ColumnSpacing="16">
                <Image Grid.Column="0"
                       Source="{Binding FlyoutIcon}"
                       HeightRequest="22"
                       WidthRequest="22"
                       Aspect="AspectFit"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <!-- Cabecera del menu -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource Primary}" HeightRequest="140" Padding="20,44,20,16">
            <VerticalStackLayout VerticalOptions="End" Spacing="4">
                <Image Source="app_logo.png" WidthRequest="52" HeightRequest="52" HorizontalOptions="Start" />
                <Label Text="TXT Reader" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource White}" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Menu hamburguesa: Inicio + Acerca de (minimo obligatorio, A.9).
         Los titulos se localizan desde el code-behind (seccion 8). -->
    <FlyoutItem x:Name="HomeFlyoutItem" Title="Home" FlyoutIcon="ic_home.png">
        <ShellContent ContentTemplate="{DataTemplate pages:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="AboutFlyoutItem" Title="About" FlyoutIcon="ic_info.png">
        <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}" Route="AboutPage" />
    </FlyoutItem>

</Shell>
